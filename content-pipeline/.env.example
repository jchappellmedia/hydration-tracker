# Copy this file to .env and fill in your real keys.
# NEVER commit .env — it is gitignored.

# KIE.ai — https://kie.ai (video / image / music / speech generation)
KIE_API_KEY=your_kie_api_key_here

# Late (getlate.dev / Zernio) — social media posting
LATE_API_KEY=sk_your_late_api_key_here

# Optional overrides (used by tests / self-hosted proxies)
# KIE_BASE_URL=https://api.kie.ai
# LATE_BASE_URL=https://getlate.dev/api/v1
